# ─── BurnBox Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# Helius RPC (Solana mainnet)
VITE_HELIUS_API_KEY=your-helius-api-key-here

# Firebase
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.europe-west1.firebasedatabase.app

# Jupiter Swap (optional)
VITE_JUPITER_API_KEY=

# Magic Eden CORS proxy base URL (optional override)
VITE_MAGIC_EDEN_PROXY_URL=https://corsproxy.io/?https://api-mainnet.magiceden.dev/v2
